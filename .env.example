# ── Azure OpenAI via Foundry (required for real LLM calls) ──────────────────
# The Azure OpenAI endpoint for the deployment in your Foundry hub
AZURE_OPENAI_ENDPOINT=https://your-hub.openai.azure.com/
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# Auth — one of:
#   Option A: API key
AZURE_OPENAI_API_KEY=your-key
#   Option B: DefaultAzureCredential (managed identity or `az login`)
#   No extra vars needed — just run `az login` locally or assign managed identity.

# ── Azure AI Foundry project (optional — enables tracing in Foundry portal) ─
# Without this, agents work fine but runs won't appear in the Foundry portal.
AZURE_AI_PROJECT_ENDPOINT=https://your-hub.api.azureml.ms

# ── OpenAI fallback (alternative to Azure OpenAI) ────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Local dev (no credentials) ────────────────────────────────────────────────
# MOCK_LLM=true

# ── GitHub (optional — enables real PR creation) ─────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
GITHUB_ORG=your-org
GITHUB_MODULES_REPO=terraform-azure-modules

# ── Platform ─────────────────────────────────────────────────────────────────
DEFAULT_ENVIRONMENT=dev
FRONTEND_URL=http://localhost:3000
DEMO_MODE=true

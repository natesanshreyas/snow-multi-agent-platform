# ── Copy this file to .deploy.env and fill in your values ───────────────────
#    cp .deploy.env.example .deploy.env
#    ./deploy.sh

# AKS cluster
AKS_CLUSTER=my-aks-cluster
RESOURCE_GROUP=my-resource-group

# Container registry (name only, without .azurecr.io)
ACR_NAME=myacr

# Azure OpenAI — full endpoint URL from Azure portal → your OpenAI resource → Keys and Endpoint
OPENAI_ENDPOINT=https://my-hub.openai.azure.com/

# Model deployment name in your Azure OpenAI resource
MODEL_DEPLOYMENT=gpt-4o

# GitHub
GITHUB_ORG=my-org
GITHUB_MODULES_REPO=terraform-modules-demo

# GitHub Personal Access Token (repo scope) — leave blank to run in DEMO_MODE
GITHUB_PAT=
